PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: Atlas → Connect → Drivers → Copy connection string
# Replace <password> and <dbname>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secrets — use long random strings in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — set this to your Vercel frontend URL in production
# Multiple origins comma-separated: https://foo.vercel.app,https://custom.com
CORS_ORIGIN=http://localhost:5173
